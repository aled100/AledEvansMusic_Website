---
import Base from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SongHeatmap from '../components/songlist-heatmap.jsx';
import site from '../content/site.json';

const decadeOrder = ["1960s","1970s","1980s","1990s","2000s","2010s","2020s"];
const songsByDecade = site?.songlist?.songsByDecade ?? {};
const getDecadeSongs = (d) => Array.isArray(songsByDecade[d]) ? songsByDecade[d] : [];
const allSongs = decadeOrder.flatMap(d => getDecadeSongs(d));
---
<Base title="Playlist Explorer — Aled Evans" description="Explore Aled's full songlist by era and vibe. Filter by decade or mood to find the perfect songs for your event.">
  <Header />
  <main class="section">
    <div class="container">
      <h1 class="h2 font-serif mb-2">Playlist Explorer</h1>
      <p class="lead mb-8">Filter by era or vibe to find the right songs for your event. Click a cell to explore.</p>
      <SongHeatmap client:load songs={allSongs} />
      <p class="mt-10 text-sm text-coal/60">
        Want to see the full list?
        <a href="/songlist">View by decade →</a>
      </p>
    </div>
  </main>
  <Footer />
</Base>
